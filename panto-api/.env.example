# ──────────────────────────────────────────────────────────────────────────────
# GoPay via Midtrans Payment Gateway
# Daftar di: https://dashboard.sandbox.midtrans.com (sandbox)
#            https://dashboard.midtrans.com (production)
# Aktifkan fitur "GoPay Tokenization" di Settings > Payment Methods
# ──────────────────────────────────────────────────────────────────────────────

# Wajib — dari Midtrans Dashboard → Settings → Access Keys
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=

# sandbox | production
MIDTRANS_ENV=sandbox

# Daftarkan GOPAY_REDIRECT_URL di Midtrans Dashboard → Settings → Snap Preferences
# → Redirect URL (atau GoPay Tokenization callback URL)
GOPAY_REDIRECT_URL=http://localhost:3000/api/gopay/callback
GOPAY_FRONTEND_CALLBACK_URL=http://localhost:5173/gopay/callback

# Override base URL (opsional)
# MIDTRANS_BASE_URL=https://api.sandbox.midtrans.com

# ──────────────────────────────
# DANA Integration
# ──────────────────────────────
DANA_CLIENT_ID=
DANA_PRIVATE_KEY_PATH=./keys/dana-private.pem
DANA_CLIENT_SECRET=
DANA_ORIGIN=http://localhost:3000
DANA_MERCHANT_ID=
DANA_ENV=sandbox

# DANA Public Key (untuk webhook verification)
DANA_PUBLIC_KEY=
